generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/**
 * ===========================
 * ENTIDADES PRINCIPALES
 * ===========================
 */

model Department {
  id               Int          @id @default(autoincrement())
  nombre           String       @unique
  slug             String       @unique
  users            User[]
  ticketTypes      TicketType[]
  ticketsAsignados Ticket[]     @relation("TicketsDepartamentoActual")
  Document         Document[]
}

model User {
  id             Int         @id @default(autoincrement())
  nombre         String
  apellido       String
  cedula         String      @unique
  email          String      @unique
  passwordHash   String
  rol            Rol
  departamentoId Int?
  departamento   Department? @relation(fields: [departamentoId], references: [id])

  //facultad
  facultad String?
  
  //CRU/Extensión (NUEVO - AGREGADO AQUÍ)
  cru String?

  // Seguridad / autenticación
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  mustChangePassword Boolean   @default(false)

  ticketsEstudiante Ticket[]        @relation("TicketsEstudiante")
  messages          TicketMessage[]
  auditLogs         AuditLog[]      @relation("UserAuditLogs")
  Document          Document[]

  // Relación con lecturas de notificaciones
  NotificationRead NotificationRead[]
  // Como actor opcional en notificaciones
  Notification     Notification[]   @relation("UserAsActor")
}

enum Rol {
  estudiante
  recepcion
  departamento
  maestro
}

model TicketType {
  id           Int        @id @default(autoincrement())
  nombre       String     @unique
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  tickets      Ticket[]
}

model Ticket {
  id    Int    @id @default(autoincrement())
  token String @unique

  estudianteId Int
  estudiante   User @relation("TicketsEstudiante", fields: [estudianteId], references: [id])

  departamentoActualId Int
  departamentoActual   Department @relation("TicketsDepartamentoActual", fields: [departamentoActualId], references: [id])

  tipoId Int
  tipo   TicketType @relation(fields: [tipoId], references: [id])

  asunto      String
  descripcion String

  // Campo CRU ELIMINADO - ahora está en User
  // cru            String? ❌ ELIMINADO
  
  categoriaQueja String? // Categoría de queja si aplica (texto)

  estado    Estado   @default(abierto)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages    TicketMessage[]
  attachments TicketAttachment[]
  auditLogs   AuditLog[]         @relation("TicketAuditLogs")

  @@index([estudianteId])
  @@index([departamentoActualId])
  @@index([tipoId])
}

enum Estado {
  abierto
  en_progreso
  completado
  cerrado
}

model TicketMessage {
  id            Int      @id @default(autoincrement())
  ticketId      Int
  ticket        Ticket   @relation(fields: [ticketId], references: [id])
  autorUserId   Int
  autor         User     @relation(fields: [autorUserId], references: [id])
  contenidoHtml String
  createdAt     DateTime @default(now())

  @@index([ticketId])
  @@index([autorUserId])
}

model TicketAttachment {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  messageId Int?
  filename  String
  pathLocal String
  mime      String?
  size      Int?
  createdAt DateTime @default(now())

  @@index([ticketId])
}

model Result {
  id           Int              @id @default(autoincrement())
  cedula       String
  convocatoria String
  facultad     String
  puntaje      Float?
  estatus      ResultadoEstatus
  createdAt    DateTime         @default(now())
}

enum ResultadoEstatus {
  Aprobado
  No_aprobado
  En_revision
}

/**
 * ===========================
 * AUDITORÍA / HISTORIAL
 * ===========================
 */

enum AuditAction {
  CREATE_TICKET
  ADD_REPLY
  REASSIGN
  COMPLETE
  UPDATE_TICKET

  UPLOAD_DOC
  VIEW_DOC
  EDIT_DOC
  DELETE_DOC
}

model AuditLog {
  id        Int         @id @default(autoincrement())
  ticketId  Int
  ticket    Ticket      @relation("TicketAuditLogs", fields: [ticketId], references: [id])
  actorId   Int
  actor     User        @relation("UserAuditLogs", fields: [actorId], references: [id])
  action    AuditAction
  details   String?
  createdAt DateTime    @default(now())

  @@index([ticketId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

model Document {
  id           Int         @id @default(autoincrement())
  title        String
  filename     String
  originalName String
  mime         String?
  size         Int?
  uploaderId   Int
  uploader     User        @relation(fields: [uploaderId], references: [id])
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  lastViewedAt DateTime?
  lastEditedAt DateTime?

  @@index([uploaderId])
  @@index([departmentId])
  @@index([createdAt])
}

/**
 * ===========================
 * NOTIFICACIONES 
 * ===========================
 */

enum NotificationType {
  TICKET_CREATED
  TICKET_REPLIED
  TICKET_REASSIGNED
  TICKET_COMPLETED
}

model Notification {
  id           Int              @id @default(autoincrement())
  type         NotificationType
  message      String
  ticketId     Int?
  actorId      Int?
  actor        User?            @relation("UserAsActor", fields: [actorId], references: [id])
  departmentId Int?
  createdAt    DateTime         @default(now())

  reads NotificationRead[]

  @@index([createdAt])
  @@index([departmentId])
}

model NotificationRead {
  userId         Int
  notificationId Int
  readAt         DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  notification Notification @relation(fields: [notificationId], references: [id])

  @@id([userId, notificationId])
}